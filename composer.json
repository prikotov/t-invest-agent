{
    "name": "t-invest/agent",
    "description": "Financial Analyst AI Agent - composer-based skill aggregator",
    "type": "project",
    "license": "MIT",
    "keywords": ["ai", "agent", "financial", "analyst", "skills", "opencode"],
    "authors": [
        {
            "name": "Dmitry Prikotov",
            "email": "prikotov@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "prikotov/moex-core": "@dev",
        "prikotov/news-core": "@dev",
        "prikotov/t-invest-core": "@dev",
        "symfony/console": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/filesystem": "8.0.*",
        "symfony/flex": "^2.7.1",
        "symfony/framework-bundle": "8.0.*",
        "symfony/runtime": "8.0.*",
        "symfony/yaml": "8.0.*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.7",
        "vimeo/psalm": "^5.0|^6.0"
    },
    "config": {
        "allow-plugins": {
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts",
            "@php vendor/bin/phpcs --config-set installed_paths $(pwd)/devops/phpcs"
        ],
        "post-update-cmd": [
            "@auto-scripts",
            "@php vendor/bin/phpcs --config-set installed_paths $(pwd)/devops/phpcs"
        ],
        "test": "phpunit",
        "cs-check": "phpcs --standard=devops/phpcs/TInvestAgentCodingStandard/ruleset.xml src tests",
        "cs-fix": "phpcbf --standard=devops/phpcs/TInvestAgentCodingStandard/ruleset.xml src tests",
        "stan": "phpstan analyse",
        "psalm": "psalm"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*"
        }
    },
    "bin": [
        "bin/agent"
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/prikotov/moex-core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/prikotov/t-invest-core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/prikotov/news-core"
        }
    ]
}
