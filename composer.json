{
    "name": "t-invest/agent",
    "description": "Financial Analyst AI Agent - composer-based skill aggregator",
    "type": "project",
    "license": "MIT",
    "keywords": ["ai", "agent", "financial", "analyst", "skills", "opencode"],
    "authors": [
        {
            "name": "Dmitry Prikotov",
            "email": "prikotov@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "prikotov/moex-core": "@dev",
        "prikotov/t-invest-core": "@dev",
        "prikotov/news-core": "@dev",
        "symfony/config": "^6.4|^7.0|^8.0",
        "symfony/console": "^6.4|^7.0|^8.0",
        "symfony/dependency-injection": "^6.4|^7.0|^8.0",
        "symfony/dotenv": "^6.4|^7.0|^8.0",
        "symfony/filesystem": "^6.4|^7.0|^8.0",
        "symfony/yaml": "^6.4|^7.0|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "bin": [
        "bin/agent"
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/prikotov/moex-core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/prikotov/t-invest-core"
        },
        {
            "type": "vcs",
            "url": "https://github.com/prikotov/news-core"
        }
    ],
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
