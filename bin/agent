#!/usr/bin/env php
<?php

declare(strict_types=1);

use Symfony\Component\Console\Application;
use Symfony\Component\Console\Command\Command;
use Symfony\Component\Console\Input\InputInterface;
use Symfony\Component\Console\Output\OutputInterface;
use Symfony\Component\Console\Style\SymfonyStyle;

require __DIR__ . '/../vendor/autoload.php';

#[\Symfony\Component\Console\Attribute\AsCommand(name: 'skills:list', description: 'List available skills')]
class SkillsListCommand extends Command
{
    protected function execute(InputInterface $input, OutputInterface $output): int
    {
        $io = new SymfonyStyle($input, $output);
        $skillsDir = dirname(__DIR__) . '/skills';

        if (!is_dir($skillsDir)) {
            $io->comment('No skills directory found.');
            return Command::SUCCESS;
        }

        $skills = glob($skillsDir . '/*/SKILL.md');

        if (empty($skills)) {
            $io->comment('No skills found.');
            return Command::SUCCESS;
        }

        $io->section('Available Skills');

        foreach ($skills as $skillFile) {
            $skillName = basename(dirname($skillFile));
            $io->writeln(sprintf('  - <comment>%s</comment>', $skillName));
        }

        return Command::SUCCESS;
    }
}

#[\Symfony\Component\Console\Attribute\AsCommand(name: 'bin:list', description: 'List available vendor binaries')]
class BinListCommand extends Command
{
    protected function execute(InputInterface $input, OutputInterface $output): int
    {
        $io = new SymfonyStyle($input, $output);
        $binDir = dirname(__DIR__) . '/vendor/bin';

        if (!is_dir($binDir)) {
            $io->comment('No vendor/bin directory found. Run composer install first.');
            return Command::SUCCESS;
        }

        $io->section('Available Binaries');

        foreach (glob($binDir . '/*') as $binary) {
            if (is_executable($binary)) {
                $name = basename($binary);
                $io->writeln(sprintf('  ./vendor/bin/<comment>%s</comment>', $name));
            }
        }

        $io->section('Examples');
        $io->writeln('  ./vendor/bin/moex security:specification SBER');
        $io->writeln('  ./vendor/bin/skill portfolio:analyze');
        $io->writeln('  ./vendor/bin/news news:fetch --ticker SBER');

        return Command::SUCCESS;
    }
}

$application = new Application('T-Invest Agent', '1.0.0');
$application->add(new SkillsListCommand());
$application->add(new BinListCommand());
$application->setDefaultCommand('bin:list');
$application->run();
